# ============================================================
# AutoLink Maroc — Variables d'environnement Backend
# Copiez ce fichier en .env et remplissez vos valeurs
# ============================================================

# Serveur
PORT=5000
NODE_ENV=development

# Base de données MySQL (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=autolink_maroc
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=autolink_maroc_secret_change_en_production
JWT_EXPIRES_IN=7d

# Upload fichiers
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Frontend URL (CORS)
CLIENT_URL=http://localhost:3000

# Anthropic API — Chatbot IA
# Obtenez votre clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-votre-cle-ici
